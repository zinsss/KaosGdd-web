# Core app
APP_NAME=KaosGdd Web
APP_TIMEZONE=Asia/Seoul
APP_HEALTH_MODE=frozen-v0-raw-edit

# Database
DATABASE_URL=sqlite:////data/kaosgdd.db

# Web/app URL
APP_BASE_URL=
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000
NEXT_PUBLIC_APP_TIMEZONE=Asia/Seoul

# File storage
FILE_STORAGE_DIR=/data/uploads

# Reminder defaults
DEFAULT_SNOOZE_MINUTES=10
REMINDER_MISSED_SCAN_LOOKBACK_HOURS=2

# Lifecycle retention
LIFECYCLE_DONE_RETENTION_DAYS=365
LIFECYCLE_REMOVED_RETENTION_DAYS=90
LIFECYCLE_FIRED_RETENTION_DAYS=30

# Notifications
PUSHOVER_ENABLED=0
PUSHOVER_PRIORITY_DEFAULT=0
PUSHOVER_DEVICE=

# Pushover secrets
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=
